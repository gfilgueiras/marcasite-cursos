# =============================================================================
# Marcasite — variáveis do projeto (raiz)
# Copie para .env e preencha os valores. Não commite o .env.
# backend/.env e frontend/.env podem ser symlinks para este ficheiro.
# =============================================================================

# --- Docker / MySQL (alinhado ao docker-compose.yml) ---
MYSQL_DATABASE=marcasite
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=aflow
MYSQL_PASSWORD=aflow

# --- URLs (browser → API e redirects do Stripe Checkout) ---
API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# --- Laravel (backend) ---
APP_NAME=Marcasite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=marcasite
DB_USERNAME=aflow
DB_PASSWORD=aflow

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

STRIPE_MODE=sandbox
STRIPE_SANDBOX_PUBLISHABLE_KEY=
STRIPE_SANDBOX_SECRET_KEY=
STRIPE_SANDBOX_WEBHOOK_SECRET=

STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=


VITE_API_URL=http://localhost:8080
VITE_STRIPE_PUBLISHABLE_KEY=
