# Copie para .env na raiz: cp .env.example .env
# O docker-compose monta este ficheiro em backend e frontend (./.env → containers).
# Opcional no host: ln -s ../.env backend/.env && ln -s ../.env frontend/.env (CLI local sem Docker)

MYSQL_DATABASE=marcasite
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=aflow
MYSQL_PASSWORD=aflow

API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Ver backend/.env.example para todas as variáveis Laravel + Stripe + VITE_*
