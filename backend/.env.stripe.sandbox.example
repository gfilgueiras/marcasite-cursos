# Copie estas linhas para o seu backend/.env enquanto desenvolve (modo teste do Stripe).
# Onde obter cada valor: veja a resposta do assistente ou o comentário no .env.example principal.

STRIPE_MODE=sandbox

STRIPE_SANDBOX_PUBLISHABLE_KEY=pk_test________________________________
STRIPE_SANDBOX_SECRET_KEY=sk_test________________________________
# Webhook: Stripe CLI (`stripe listen`) ou endpoint de teste no Dashboard → Signing secret whsec_...
STRIPE_SANDBOX_WEBHOOK_SECRET=whsec________________________________
