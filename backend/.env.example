APP_NAME=Marcasite
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=marcasite
DB_USERNAME=aflow
DB_PASSWORD=aflow

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

# -----------------------------------------------------------------------------
# Stripe — escolha o modo ativo
# -----------------------------------------------------------------------------
# sandbox = chaves de teste (pk_test_ / sk_test_ / whsec_ da CLI ou endpoint de teste)
# live    = chaves de produção (pk_live_ / sk_live_ / whsec_ do endpoint live)
# -----------------------------------------------------------------------------
STRIPE_MODE=sandbox

# --- Sandbox (teste) — preencha com o que copiar do Dashboard em "Modo de teste" ---
STRIPE_SANDBOX_PUBLISHABLE_KEY=
STRIPE_SANDBOX_SECRET_KEY=
STRIPE_SANDBOX_WEBHOOK_SECRET=

# --- Produção — só use com STRIPE_MODE=live em ambiente seguro ---
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=

# --- Legado (opcional): se preenchido, sandbox usa estes quando os STRIPE_SANDBOX_* estiverem vazios ---
# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=
